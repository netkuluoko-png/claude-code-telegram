{
  "mcpServers": {
    "process-manager": {
      "command": "python",
      "args": ["-m", "src.process.mcp_server"],
      "cwd": "/app",
      "env": {
        "PYTHONPATH": "/app"
      }
    },
    "telegram": {
      "command": "python",
      "args": ["-m", "src.mcp.telegram_server"],
      "cwd": "/app",
      "env": {
        "PYTHONPATH": "/app"
      }
    },
    "mcp-scheduler": {
      "command": "python",
      "args": ["-m", "src.scheduler_mcp.mcp_server"],
      "cwd": "/app",
      "env": {
        "PYTHONPATH": "/app",
        "SCHEDULER_DB_PATH": "/app/data/bot.db"
      }
    }
  }
}
